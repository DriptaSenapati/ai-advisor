generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model NormalizedTransactions {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  date                DateTime
  description         String
  creditAmount        Float
  debitAmount         Float
  balance             Float
  statementMetadataId String?            @db.ObjectId
  statementMetadata   StatementMetadata? @relation("NormalizedTransactionsMetadata", fields: [statementMetadataId], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model ExceptionTransactions {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  date                DateTime?
  description         String?
  creditAmount        String?
  debitAmount         String?
  balance             String?
  statementMetadataId String?            @db.ObjectId
  statementMetadata   StatementMetadata? @relation("ExceptionTransactionsMetadata", fields: [statementMetadataId], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

