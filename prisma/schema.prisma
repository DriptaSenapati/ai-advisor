model FinalTransactionData {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  date                DateTime
  description         String
  creditAmount        Float
  debitAmount         Float
  balance             Float
  clusterId           String?            @db.ObjectId
  cluster             Cluster?           @relation(fields: [clusterId], references: [id])
  descriptionVector   Float[]
  statementMetadataId String?            @db.ObjectId
  statementMetadata   StatementMetadata? @relation(fields: [statementMetadataId], references: [id])
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Cluster {
  id                       String                 @id @default(auto()) @map("_id") @db.ObjectId
  transactions             FinalTransactionData[]
  clusterLength            Int
  merchantName             String?
  category                 String?
  confidence               Float?
  categorySupportRationale String?
  centroid                 String
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  recurringPatterns        RecurringPattern[]
}

model MonthlyStats {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  month             String
  totalIncome       Float
  totalExpenses     Float
  netSavings        Float
  savingsRate       Float
  closingBalance    Float
  totalRefunds      Float
  refundCount       Int
  categoryBreakdown Json[]
  topMerchants      Json[]
  weekdayVsWeekend  Json
  timeOfMonth       Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RecurringPattern {
  id                     String    @id @default(auto()) @map("_id") @db.ObjectId
  clusterId              String    @db.ObjectId
  cluster                Cluster   @relation(fields: [clusterId], references: [id])
  merchantName           String?
  category               String?
  estimatedMonthlyAmount Float
  frequency              String
  monthsDetected         Int
  isCancellable          Boolean
  isActive               Boolean
  lastTransactionDate    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model InsightReport {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  generatedAt      DateTime @default(now())
  monthsCovered    String[]
  tier             Int
  insights         Json
  rawStatsSnapshot Json
  createdAt        DateTime @default(now())
}

model Goal {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  goalType       String
  targetAmount   Float
  deadline       DateTime
  categoryTarget String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ErrorPdfExtract {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  action              String
  rationale           String
  row                 Json
  statementMetadataId String?            @db.ObjectId
  statementMetadata   StatementMetadata? @relation("ErrorPdfExtractMetadata", fields: [statementMetadataId], references: [id])
  createdAt           DateTime           @default(now())
}

model StatementMetadata {
  id                     String                   @id @default(auto()) @map("_id") @db.ObjectId
  bankName               String
  statementPeriodStart   DateTime?
  statementPeriodEnd     DateTime?
  contentHash            String                   @unique
  totalTransactions      Int?
  exceptionCount         Int?
  normalizerStatus       String                   @default("Processing") // "Processing" | "Completed" | "Error"
  insightsStatus         String                   @default("Processing") // "Processing" | "Completed" | "Error"
  normalizerError        String?
  insightsError          String?
  transactions           FinalTransactionData[]
  normalizedTransactions NormalizedTransactions[] @relation("NormalizedTransactionsMetadata")
  exceptionTransactions  ExceptionTransactions[]  @relation("ExceptionTransactionsMetadata")
  errorPdfExtracts       ErrorPdfExtract[]        @relation("ErrorPdfExtractMetadata")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
}
